DT_COMPAT_ZMK_INPUT_PROCESSOR_GESTURES := zmk,input-processor-gestures

config ZMK_INPUT_PROCESSOR_GESTURES
		bool
		default $(dt_compat_enabled,$(DT_COMPAT_ZMK_INPUT_PROCESSOR_GESTURES))
        depends on ZMK_POINTING
        depends on (!ZMK_SPLIT || ZMK_SPLIT_ROLE_CENTRAL)

config INPUT_GESTURES_INIT_PRIORITY
    int "Touchpad gestures initialization priority"
    default INPUT_INIT_PRIORITY
    depends on ZMK_INPUT_PROCESSOR_GESTURES

DT_COMPAT_ZMK_INPUT_PERIPHERAL_GESTURE := zmk,input-peripheral-gesture

config ZMK_INPUT_PERIPHERAL_GESTURE
        bool
        default $(dt_compat_enabled,$(DT_COMPAT_ZMK_INPUT_PERIPHERAL_GESTURE))
        depends on ZMK_POINTING
        depends on (!ZMK_SPLIT || !ZMK_SPLIT_ROLE_CENTRAL)

config ZMK_INPUT_PERIPHERAL_GESTURE_WORKQ_STACK_SIZE
        int "Peripheral gesture work queue stack size"
        depends on ZMK_INPUT_PERIPHERAL_GESTURE
        default 2048

config ZMK_INPUT_PERIPHERAL_GESTURE_WORKQ_PRIORITY
        int "Peripheral gesture work queue thread priority"
        depends on ZMK_INPUT_PERIPHERAL_GESTURE
        default 5

DT_COMPAT_ZMK_KSCAN_TOUCH_DETECT := zmk,kscan-touch-detect

config ZMK_KSCAN_TOUCH_DETECT
        bool
        default $(dt_compat_enabled,$(DT_COMPAT_ZMK_KSCAN_TOUCH_DETECT))

config ZMK_HEARTBEAT_LED
        bool "Blink built-in LED as heartbeat (crash detection)"
        depends on GPIO
        help
          Blinks the led0 alias at 1 Hz. If blinking stops, the MCU crashed.
          If BLE drops but blinking continues, the fault is in the BLE link.

